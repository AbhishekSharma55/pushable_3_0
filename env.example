# ─── Database ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=pushable_ai

# ─── Auth ───
# Must be at least 32 characters
JWT_SECRET=change-me-to-a-32-char-random-string

# ─── API Keys ───
OPENROUTER_KEY=sk-or-v1-your-key-here
COMPOSIO_API_KEY=ak_your-key-here
CAPSOLVER_API_KEY=CAP-your-key-here

# ─── Capsolver ───
CAPSOLVER_EXTENSION_ENABLED=true

# ─── URLs (change these for production domain) ───
FRONTEND_URL=https://platform.pushable.ai
NEXT_PUBLIC_API_URL=https://api.pushable.ai
NEXT_PUBLIC_BROWSER_WS_URL=wss://browser.pushable.ai
NEXT_PUBLIC_FRONTEND_URL=https://platform.pushable.ai
EXTENSION_BRIDGE_PUBLIC_URL=wss://ws.pushable.ai

# ─── Ports (optional, defaults shown) ───
# FRONTEND_PORT=3000
# PUBLIC_FRONTEND_PORT=3001
# BACKEND_PORT=4000
# BROWSER_SERVICE_PORT=8080

# ─── Extension Bridge (Chrome extension automation) ───
EXTENSION_BRIDGE_URL=ws://extension-bridge:3001
EXTENSION_BRIDGE_API_KEY=

# ─── Browser Agent Model (OpenRouter model ID for browser automation sub-agent) ───
DEFAULT_BROWSER_AGENT_MODEL=google/gemini-2.5-flash

# ─── CDP Analyzer (Python DOM analysis service) ───
CDP_ANALYZER_URL=http://cdp-analyzer:5050

# ─── Vault Integration (encrypts stored vault credentials, generate a random 32-byte key) ───
VAULT_ENCRYPTION_KEY=
